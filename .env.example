# LLM Data Service — 环境变量配置

# 认证（必填）
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# 生成密码哈希：
# cd backend && .venv/bin/python -c "import bcrypt; print(bcrypt.hashpw(b'your-password', bcrypt.gensalt()).decode())"

# 可选
# DATA_DIR=/app/data
# LOG_DIR=/app/logs
# DB_PATH=/app/app.db
# SUPERVISOR_POLL_SECONDS=30
